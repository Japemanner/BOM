DATABASE_URL=postgresql://user:pass@host:5432/dbname
BETTER_AUTH_SECRET=vervang_dit_met_random_32_char_string
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 32-byte AES-256 sleutel voor het versleutelen van webhook tokens
# Genereer met: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=vervang_dit_met_64_hex_tekens
